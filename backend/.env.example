APP_NAME=Alma Leads API
APP_ENV=local
DATABASE_URL=sqlite:///./storage/leads.db
PUBLIC_WEB_URL=http://localhost:3000
INTERNAL_ATTORNEY_EMAIL=attorney@example.com
FROM_EMAIL=leads@example.com
ADMIN_USERNAME=attorney@company.com
ADMIN_PASSWORD=change-me
AUTH_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:3000

# Optional SMTP integration. When SMTP_HOST is empty, emails are written to storage/outbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
