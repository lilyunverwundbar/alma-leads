APP_NAME=Alma Leads API
APP_ENV=local
DATABASE_URL=sqlite:///./storage/leads.db
PUBLIC_WEB_URL=http://127.0.0.1:3000
INTERNAL_ATTORNEY_EMAIL=lilyunverwundbar@gmail.com
FROM_EMAIL=lilyunverwundbar@gmail.com
ADMIN_USERNAME=attorney@company.com
ADMIN_PASSWORD=change-me
AUTH_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP email integration. When SMTP_HOST is empty, emails are written to storage/outbox.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=replace-with-your-sendgrid-api-key
SMTP_USE_TLS=true
SMTP_USE_SSL=false
